    "trailer": {
      "damagePad": {
        "mode": "stock",
        "defaultImage": "container",
        "images": [
          "container",
          "trailer"
        ]
      },
      "fields": [
        {
          "id": "exterior_damage_buttons",
          "label": "Visible Exterior Damage?",
          "type": "segmented",
          "options": [
            "Pass",
            "Fail"
          ]
        },
        {
          "id": "floor_condition",
          "label": "Floor Condition",
          "type": "dropdown",
          "options": [
            "Clean & Dry",
            "Damaged",
            "Minor Debris",
            "Wet"
          ],
          "required": true
