    "trailer": {
      "damagePad": {
        "mode": "stock",
        "defaultImage": "container",
        "images": [
          "container",
          "trailer"
        ]
      },
      "fields": [
        {
          "id": "exterior_damage_buttons",
          "label": "Visible exterior damage? (Pass/Fail buttons)",
          "type": "segmented",
          "options": [
            "Pass",
            "Fail"
          ]
        },
        {
          "id": "exterior_damage_toggles",
          "label": "Visible exterior damage? (Pass/Fail toggles)",
          "type": "toggle_pair",
          "options": [
            "Pass",
            "Fail"
          ]
        },
        {
          "id": "floor_condition",
          "label": "Floor condition",
          "type": "dropdown",
          "options": [
            "Clean & Dry",
            "Minor Debris",
            "Damaged",
            "Wet"
          ],
          "required": true
        },
        {
          "id": "door_seals_locks",
          "label": "Door seals & locks",
          "type": "segmented",
          "options": [
            "Pass",
            "Fail"
          ]
        },
        {
          "id": "interior_cleanliness",
