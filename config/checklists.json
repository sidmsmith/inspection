          "type": "segmented",
          "options": [
            "Pass",
            "Fail"
          ]
        },
        {
          "id": "interior_cleanliness",
          "label": "Interior Cleanliness",
          "type": "dropdown",
          "options": [
            "Acceptable",
            "Clean",
            "Needs Cleaning"
          ]
